					},
					{
						"name": " NO_OF_TRADES",
						"type": "String"
					},
					{
						"name": " DELIV_QTY",
						"type": "String"
					},
					{
						"name": " DELIV_PER",
						"type": "String"
					}
				]
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/linked_service_blob_storage')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/dataset_csv_tgt')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "linked_service_blob_storage",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "DelimitedText",
				"typeProperties": {
					"location": {
						"type": "AzureBlobStorageLocation",
						"folderPath": "tgt",
						"container": "demo-container1"
					},
					"columnDelimiter": ",",
					"escapeChar": "\\",
					"firstRowAsHeader": true,
					"quoteChar": "\""
				},
				"schema": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/linked_service_blob_storage')]"
			]
		},
		{
