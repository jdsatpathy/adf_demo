					},
					{
						"name": " PREV_CLOSE",
						"type": "String"
					},
					{
						"name": " OPEN_PRICE",
						"type": "String"
					},
					{
						"name": " HIGH_PRICE",
						"type": "String"
					},
					{
						"name": " LOW_PRICE",
						"type": "String"
					},
					{
						"name": " LAST_PRICE",
						"type": "String"
					},
					{
						"name": " CLOSE_PRICE",
						"type": "String"
					},
					{
						"name": " AVG_PRICE",
						"type": "String"
					},
					{
						"name": " TTL_TRD_QNTY",
						"type": "String"
					},
					{
						"name": " TURNOVER_LACS",
